{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@logchimp/api",
  "description": "LogChimp APIs",
  "version": "0.9.0-alpha.1",
  "main": "./index.js",
  "scripts": {
    "dev": "nodemon",
    "start": "node index.js",
    "test:unit": "vitest --config ./vitest.config.unit.ts",
    "test:integration": "vitest --config ./vitest.config.integration.ts",
    "db:migrate:create": "knex --knexfile ./src/database/config.ts migrate:make",
    "db:seed:run": "knex --knexfile ./src/database/config.ts seed:run"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "fs-extra": "^11.3.4",
    "html-to-text": "^8.2.1",
    "iovalkey": "^0.3.3",
    "jsdom": "^20.0.3",
    "jsonwebtoken": "^9.0.3",
    "knex": "^2.5.1",
    "lodash": "^4.18.1",
    "md5": "^2.3.0",
    "nanoid": "^3.3.11",
    "nodemailer": "8.0.5",
    "pg": "^8.7.1",
    "uuid": "^9.0.1",
    "valibot": "^1.2.0",
    "validator": "^13.15.35",
    "winston": "^3.3.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@logchimp/types": "workspace:*",
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.2.0",
    "@types/express": "^5.0.3",
    "@types/html-to-text": "^9.0.4",
    "@types/jsdom": "^21.1.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/md5": "^2.3.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.1.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "10.0.0",
    "@types/validator": "^13.15.10",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=22 < 23"
  }
}
